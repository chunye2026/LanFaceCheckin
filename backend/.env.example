# 环境变量模板 - 复制为 .env 并填入真实值
# 警告: 不要提交 .env 到 Git 仓库！

# ====== 安全配置 (必填) ======
SECRET_KEY=请替换为强随机字符串至少32位
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=
# 如果 ADMIN_INIT_PASSWORD 为空，系统生成随机密码并打印到控制台

# ====== 数据库 ======
DATABASE_URL=sqlite:///data/checkin.db
# 正式环境建议:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/lanfacecheckin

# ====== CORS 允许的域名 (逗号分隔) ======
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5000,https://127.0.0.1:5000

# ====== 人脸识别 ======
FACE_MATCH_THRESHOLD=0.65
CHECKIN_INTERVAL_SECONDS=300
CAMERA_INDEX=0
ENABLE_LIVENESS=false
MIN_FACE_SAMPLES=3
MAX_FACE_SAMPLES=5
DETECTION_EVERY_N_FRAMES=5
COOLDOWN_SECONDS=300
ALLOW_MULTIPLE_IN_OUT=true

# ====== Dashboard 大屏 ======
DASHBOARD_DRAW_FACE_BOX=true
DASHBOARD_SHOW_PHONE=true
DASHBOARD_SHOW_EMAIL=true
DASHBOARD_MASK_PHONE=true
DASHBOARD_MASK_EMAIL=true
DASHBOARD_TOP_N=10
WORKDAY_WEEKDAYS=0,1,2,3,4
ATTENDANCE_DAY_RULE=any_record

# ====== Flask ======
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_USE_SSL=false
